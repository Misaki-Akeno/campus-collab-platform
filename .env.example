# 复制本文件为项目根目录的 .env，.env 已加入 .gitignore 不会进版本库
#
# 注入方式：
#   本地 CLI  : make run-user / make run-gateway（Makefile 自动 -include .env）
#   Docker    : docker-compose.yml 中 env_file: - ./.env
#   IntelliJ  : Run Configuration → EnvFile 插件 → 选择项目根 .env
#   VSCode    : launch.json 中 envFile 字段指向 ${workspaceFolder}/.env

# ==================== JWT ====================
# HMAC-SHA256，Base64 编码，至少 32 字节原始长度
CAMPUS_JWT_SECRET=your-base64-encoded-secret-at-least-32-bytes

# ==================== 数据库 ====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=campus_platform
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me

# ==================== Redis ====================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=    # 生产环境必填；本地无认证可留空

# ==================== Kafka ====================
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# ==================== Nacos ====================
NACOS_SERVER_ADDR=127.0.0.1:8848

# ==================== MinIO ====================
MINIO_ENDPOINT=http://127.0.0.1:9002
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=campus-files
