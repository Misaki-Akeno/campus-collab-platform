meta {
  name: 01 - 活动列表
  type: http
  seq: 1
}

get {
  url: {{gateway_url}}/seckill/api/v1/activities?page=1&size=10
  auth: none
}

tests {
  test("活动列表 - HTTP 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("活动列表 - code 200", function() {
    expect(res.getBody().code).to.equal(200);
  });

  test("活动列表 - 返回分页结构", function() {
    const data = res.getBody().data;
    expect(data).to.be.an('object');
    expect(data.total).to.be.a('number');
    expect(data.records).to.be.an('array');
    // 保存第一条活动 ID，供后续报名测试使用
    if (data.records && data.records.length > 0) {
      bru.setEnvVar("registered_activity_id", String(data.records[0].id));
    }
  });
}
