meta {
  name: 03 - 刷新 Token
  type: http
  seq: 3
}

post {
  url: {{gateway_url}}/user/api/v1/token/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refresh_token}}"
  }
}

tests {
  test("刷新成功 - HTTP 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("刷新成功 - 返回新 accessToken", function() {
    const data = res.getBody().data;
    expect(data.accessToken).to.not.be.null();
    bru.setEnvVar("access_token", data.accessToken);
  });
}
