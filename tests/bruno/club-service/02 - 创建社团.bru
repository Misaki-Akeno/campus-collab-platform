meta {
  name: 02 - 创建社团
  type: http
  seq: 2
}

post {
  url: {{gateway_url}}/club/api/v1/clubs
  body: json
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

script:pre-request {
  bru.setVar("club_name", "test-club-" + Date.now());
}

body:json {
  {
    "name": "{{club_name}}",
    "description": "auto-test",
    "category": "academic"
  }
}

tests {
  test("创建社团 - HTTP 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("创建社团 - code 200", function() {
    expect(res.getBody().code).to.equal(200);
  });

  test("创建社团 - 返回 clubId", function() {
    const data = res.getBody().data;
    expect(data.clubId).to.not.be.null;
    bru.setEnvVar("registered_club_id", data.clubId);
  });
}
